{
  "uid": "cloud-api-logs",
  "title": "🔍 Cloud API Security - Logs",
  "description": "Real-time observability dashboard - Promtail → Loki → Grafana",
  "tags": ["logs", "observability", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "current": { "text": "All", "value": "" },
        "definition": "label_values(service)",
        "allValue": ".*",
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "refresh": 1
      },
      {
        "name": "level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "current": { "text": "All", "value": "" },
        "definition": "label_values(level)",
        "allValue": ".*",
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "📊 Total Logs (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({} [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "⚠️ Errors (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({level=\"ERROR\"} [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "🐳 Containers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(count_over_time({} [1h]) by (container))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "🎯 Services Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(count_over_time({} [5m]) by (service))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "title": "📋 Real-time Logs",
      "type": "logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"$level\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "showTime": true,
        "sortOrder": 1
      }
    }
  ]
}
