# Copy file nay thanh .env khi deploy tren Ubuntu bang domain that + ZeroSSL.
# Thay apisec.shop bang domain ban mua.

POSTGRES_USER=apiuser
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=apidb
POSTGRES_PORT=5434
DATABASE_URL=postgresql://apiuser:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/apidb

REDIS_PORT=6380

VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
VAULT_KEY_NAME=orders-dek
VAULT_WRAPPED_DEK=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=cloudapi

# Issuer phai khop public hostname cua Keycloak.
JWT_ISSUER=https://auth.apisec.shop/realms/cloudapi
JWT_AUDIENCE=account

VITE_REALM=cloudapi
VITE_CLIENT_ID=spa-client
VITE_KEYCLOAK_URL=https://auth.apisec.shop
VITE_KONG_URL=https://api.apisec.shop:8443

BACKEND_CORS_ORIGINS=https://app.apisec.shop
KC_HOSTNAME=auth.apisec.shop
PUBLIC_BASE_URL=https://app.apisec.shop

GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMTAIL_LOG_LEVEL=info

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
