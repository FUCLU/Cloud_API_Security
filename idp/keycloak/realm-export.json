      {
        "name": "ecdsa-generated",
        "providerId": "ecdsa-generated",
        "subComponents": {},
        "config": {
          "priority": [
            "100"
          ],
          "enabled": [
            "true"
          ],
          "active": [
            "true"
          ],
          "ecdsaCurve": [
            "P-256"
          ]
        }
      }
    ]
  }
