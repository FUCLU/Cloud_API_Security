{
  "realm": "cloudapi",
  "enabled": true,
  "defaultSignatureAlgorithm": "ES256",

  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30
    }
  ],

  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyInitialCounter": 0,

  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 1800,

  "roles": {
    "realm": [
      { "name": "admin",    "description": "Full access" },
      { "name": "staff",    "description": "No delete" },
      { "name": "customer", "description": "Own data only" }
    ]
  },
  "defaultRoles": ["customer"],

  "clients": [
    {
      "clientId": "spa-client",
      "publicClient": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://localhost:5174/*",
        "https://app.fmsec.shop/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "https://localhost:5174",
        "https://app.fmsec.shop"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.signed.response.alg": "ES256",
        "id.token.signed.response.alg": "ES256"
      },
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true
    },
    {
      "clientId": "backend-client",
      "secret": "backend-secret",
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],

  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "authenticateByDefault": false,
      "linkOnly": false,
      "updateProfileFirstLoginMode": "off",
      "trustEmail": true,
      "storeToken": false,
      "config": {
        "clientId": "679393827886-fnimrsjluoue2n568kn0nfqt5jpmt7ip.apps.googleusercontent.com",
        "clientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET",
        "hideOnLoginPage": "true",
        "useJwksUrl": "true",
        "defaultScope": "openid profile email"
      }
    }
  ],

  "users": [
    {
      "username": "phuc@company.com",
      "email": "phuc@company.com",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "demo1234", "temporary": false }
      ],
      "realmRoles": ["admin"],
      "requiredActions": ["CONFIGURE_TOTP"]
    },
    {
      "username": "hung@company.com",
      "email": "hung@company.com",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "demo1234", "temporary": false }
      ],
      "realmRoles": ["admin"],
      "requiredActions": ["CONFIGURE_TOTP"]
    },
    {
      "username": "kiet@company.com",
      "email": "kiet@company.com",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "demo1234", "temporary": false }
      ],
      "realmRoles": ["staff"],
      "requiredActions": ["CONFIGURE_TOTP"]
