  "admin_api_import": {
    "description": "Script import users thủ công qua Keycloak Admin REST API (nếu không dùng realm-export.json)",
    "steps": [
      "1. Lấy admin token:",
      "   TOKEN=$(curl -s -X POST http://localhost:8081/realms/master/protocol/openid-connect/token -d 'client_id=admin-cli&username=admin&password=admin123&grant_type=password' | jq -r '.access_token')",
      "2. Tạo user:",
      "   curl -X POST http://localhost:8081/admin/realms/lab/users -H \"Authorization: Bearer $TOKEN\" -H 'Content-Type: application/json' -d '{...}'",
      "3. Set password:",
      "   curl -X PUT http://localhost:8081/admin/realms/lab/users/<userId>/reset-password -H \"Authorization: Bearer $TOKEN\" -H 'Content-Type: application/json' -d '{\"type\":\"password\",\"value\":\"demo1234\",\"temporary\":false}'",
      "4. Assign role:",
      "   curl -X POST http://localhost:8081/admin/realms/lab/users/<userId>/role-mappings/realm -H \"Authorization: Bearer $TOKEN\" -H 'Content-Type: application/json' -d '[{\"id\":\"role-admin\",\"name\":\"admin\"}]'"
    ]
  }
}