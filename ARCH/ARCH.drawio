    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- AUTHN LAYER BANNER -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="authn_layer" value="🪪 AUTHN LAYER — WebAuthn/FIDO2 (primary) · TOTP fallback · Auth Code + PKCE (public clients) · Client Credentials (S2S) · mTLS east-west · Short-lived tokens · Refresh token rotation + reuse-detect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;fontColor=#1B5E20;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="30" y="750" width="1300" height="40" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- AUTHZ LAYER BANNER -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="authz_layer" value="🛂 AUTHZ LAYER — deny-by-default · least-privilege · RBAC → ABAC (OPA/Rego) · PEP@Gateway + PDP@OPA · JWT pin alg / kid control · DPoP/mTLS-bound (PoP) · Log reason all decisions (100% explainability)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=10;fontColor=#E65100;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="30" y="800" width="1300" height="40" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- INVARIANTS BOX -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="invariants" value="📌 INVARIANTS&#xa;I1: 0 byte plaintext leakage on protected channel&#xa;I2: Tampering (ciphertext/token) rejected + logged&#xa;I3: Data integrity — original, unmodified&#xa;I4: AuthN anti-phishing; PoP token bound, replay=0&#xa;I5: AuthZ decisions 100% explainable from log/policy&#xa;I6: Key ops observable; rotate ≤10min; blast-radius ≤24h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=10;fontColor=#263238;align=left;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="850" width="540" height="110" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- METRICS BOX -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="metrics" value="📊 KEY METRICS &amp; THRESHOLDS&#xa;Plaintext leakage: 0 byte | AEAD error: 0 | Nonce reuse: 0&#xa;AuthN success ≥99% | False-accept = 0 | Lockout ≤1s&#xa;AuthZ pass-rate ≥95% | Undeclared action deny = 100%&#xa;Token replay (PoP): 0 | Key rotation ≤10 min | Blast-radius ≤24h&#xa;Explainability: 100% decisions reconstructable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=10;fontColor=#263238;align=left;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="590" y="850" width="540" height="110" as="geometry" />
    </mxCell>

