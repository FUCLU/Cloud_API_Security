    <mxCell id="crypto_layer" value="🔒 CRYPTO LAYER — TLS 1.3 (all channels) · AEAD AES-256-GCM / XChaCha20-Poly1305 (at-rest) · Ed25519 signatures · Envelope Encryption (KEK/DEK) · Nonce discipline enforced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=10;fontColor=#1A237E;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
