    <!-- ATTACK SURFACE BOX -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <mxCell id="attacks" value="⚠️ ATTACK SURFACE (mitigated)&#xa;BOLA: per-request server-side ACL, opaque IDs, fuzzing tests&#xa;Token theft: short-lived, PKCE, PoP (DPoP/mTLS), revocation&#xa;Webhook forgery: HMAC-signed, nonce+timestamp, IP allowlist&#xa;SSRF: egress block 169.254.x, allowlist, network egress ctrl&#xa;Rate abuse: per-IP/user limits, CAPTCHA, backoff, quotas&#xa;Supply chain: SAST, SCA, secrets scan, artifact signing, SBOM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=10;fontColor=#B71C1C;align=left;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1150" y="850" width="480" height="110" as="geometry" />
