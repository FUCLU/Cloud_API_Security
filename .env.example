# PostgreSQL
POSTGRES_DB=cloudapi
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_PORT=5434                          # Port expose: localhost:5434
DATABASE_URL=postgresql://admin:admin123@postgres:5432/cloudapi

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080          # backend
KEYCLOAK_REALM=cloudapi                    # backend

# Backend — verify JWT
JWT_AUDIENCE=cloud-api
JWT_ISSUER=http://localhost:8082/realms/cloudapi

# Backend — mã hóa dữ liệu (AEAD/AES-GCM)
# Chạy lệnh này để lấy được giá trị
# docker compose up -d vault vault-init; $dek=[Convert]::ToBase64String((1..32|%{Get-Random -Max 256})); $wrapped=docker exec -e VAULT_ADDR=http://127.0.0.1:8200 -e VAULT_TOKEN=root -e DEK_BASE64=$dek vault sh -lc 'vault write -field=ciphertext transit/encrypt/dek plaintext=$DEK_BASE64'; "VAULT_WRAPPED_DEK=$wrapped"
VAULT_WRAPPED_DEK=

# Redis
REDIS_PORT=6380                             # Port expose: localhost:6380

# Vault
VAULT_TOKEN=root
VAULT_KEY_NAME=dek

# Backend logging
LOG_LEVEL=INFO                              # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Observability — Grafana, Loki, Promtail
# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Promtail logging level (optional)
PROMTAIL_LOG_LEVEL=info                     # debug, info, warn, error

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Frontend
VITE_KEYCLOAK_URL=http://localhost:8082
VITE_KONG_URL=https://localhost:8443
VITE_REALM=cloudapi
VITE_CLIENT_ID=spa-client
