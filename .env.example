# Copy file nay thanh .env va thay CHANGE_ME_* truoc khi deploy.
# Public TLS dung certs/ ZeroSSL; internal service TLS dung internal-certs/.

POSTGRES_USER=apiuser
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=apidb
POSTGRES_PORT=5434
DATABASE_URL=postgresql://apiuser:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/apidb?sslmode=verify-full&sslrootcert=/run/secrets/internal_ca_cert

REDIS_PORT=6380
REDIS_URL=rediss://redis:6379/0
REDIS_SSL_CA_CERTS=/run/secrets/internal_ca_cert

VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
VAULT_ADDR=https://vault:8200
VAULT_CACERT=/run/secrets/internal_ca_cert
VAULT_KEY_NAME=orders-dek
VAULT_WRAPPED_DEK=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_URL=https://auth.fmsec.shop:8443
KEYCLOAK_PUBLIC_URL=https://auth.fmsec.shop
KEYCLOAK_CLIENT_ID=spa-client
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM=cloudapi
JWT_ISSUER=https://auth.fmsec.shop/realms/cloudapi
JWT_AUDIENCE=account

VITE_REALM=cloudapi
VITE_CLIENT_ID=spa-client
VITE_KEYCLOAK_URL=https://auth.fmsec.shop
VITE_KONG_URL=https://api.fmsec.shop:8443

BACKEND_CORS_ORIGINS=https://app.fmsec.shop
KC_HOSTNAME=auth.fmsec.shop
PUBLIC_BASE_URL=https://app.fmsec.shop
FRONTEND_URL=https://app.fmsec.shop

GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMTAIL_LOG_LEVEL=info

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
