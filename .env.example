# PostgreSQL
POSTGRES_DB=cloudapi
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_PORT=5434                          # Port expose: localhost:5434
DATABASE_URL=postgresql://admin:admin123@postgres:5432/cloudapi

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080          # backend
KEYCLOAK_REALM=cloudapi                    # backend

# Backend — verify JWT
JWT_AUDIENCE=cloud-api
JWT_ISSUER=http://localhost:8082/realms/cloudapi

# Backend — mã hóa dữ liệu (AEAD/AES-GCM)
# Tạo bằng: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# KHÔNG thay đổi nếu DB đã có dữ liệu — sẽ mất khả năng giải mã
DEK_BASE64=paste_kết_quả_lệnh_python_vào_đây

# Redis
REDIS_PORT=6380                             # Port expose: localhost:6380

# Vault
VAULT_TOKEN=root
VAULT_KEY_NAME=dek

# Backend logging
LOG_LEVEL=INFO                              # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Observability — Grafana, Loki, Promtail
# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Promtail logging level (optional)
PROMTAIL_LOG_LEVEL=info                     # debug, info, warn, error

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Frontend
VITE_KEYCLOAK_URL=http://localhost:8082
VITE_KONG_URL=https://localhost:8443
VITE_REALM=cloudapi
VITE_CLIENT_ID=spa-client
